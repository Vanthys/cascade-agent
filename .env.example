# ───────────────────────────────────────────────
# Gene Agent — Environment Variables
# Copy to .env and fill in real values.
# ───────────────────────────────────────────────

# ── GMI Cloud (LLM inference) ──────────────────
# Get key at: https://inference.gmi.ai/
GMI_API_KEY=your-gmi-api-key-here
GMI_BASE_URL=https://api.gmi-serving.com/v1

# Model to use for fast structured extraction / classification
GMI_FAST_MODEL=moonshotai/Kimi-K2-Instruct-0905

# Model to use for synthesis and hypothesis generation
GMI_STRONG_MODEL=moonshotai/Kimi-K2-Instruct-0905

# ── HydraDB (agent session memory) ────────────
# Get key at: https://hydradb.com  (contact their team for access)
# HYDRA_API_KEY is used by the SDK via env var HYDRADB_API_KEY
HYDRADB_API_KEY=your-hydra-api-key-here
HYDRA_BASE_URL=https://api.hydradb.com

# Tenant ID — one top-level tenant per app deployment
HYDRA_TENANT_ID=gene-agent

# ── App Database ───────────────────────────────
# SQLite (default, fine for hackathon). Swap to postgres:// for prod.
DATABASE_URL=sqlite:///./data/gene_agent.db

# ── Cache ──────────────────────────────────────
# TTL in seconds for cached gene facts / neighbor lists
CACHE_TTL_SECONDS=3600

# ── Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
